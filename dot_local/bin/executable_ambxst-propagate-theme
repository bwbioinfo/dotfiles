#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: ambxst-propagate-theme [--light|--dark]

Propagate Ambxst's theme.lightMode setting to app toolkit preferences.
EOF
}

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
theme_config="${config_home}/ambxst/config/theme.json"

read_light_mode() {
  local value

  for _ in 1 2 3 4 5; do
    if value="$(jq -r 'if (.lightMode // false) == true then "true" else "false" end' "$theme_config" 2>/dev/null)"; then
      printf '%s\n' "$value"
      return 0
    fi

    sleep 0.1
  done

  printf 'Unable to read Ambxst theme config: %s\n' "$theme_config" >&2
  return 1
}

set_ini_key() {
  local file="$1"
  local section="$2"
  local key="$3"
  local value="$4"
  local dir
  local tmp

  dir="$(dirname "$file")"
  mkdir -p "$dir"
  tmp="$(mktemp "${file}.tmp.XXXXXX")"

  if [ -s "$file" ]; then
    awk -v section="$section" -v key="$key" -v value="$value" '
      function is_section(line) {
        return line ~ /^[[:space:]]*\[[^]]+\][[:space:]]*$/
      }

      function section_name(line, name) {
        name = line
        sub(/^[[:space:]]*\[/, "", name)
        sub(/\][[:space:]]*$/, "", name)
        return name
      }

      BEGIN {
        in_section = 0
        section_seen = 0
        key_set = 0
      }

      is_section($0) {
        if (in_section && !key_set) {
          print key "=" value
          key_set = 1
        }

        in_section = (section_name($0) == section)
        if (in_section) {
          section_seen = 1
          key_set = 0
        }

        print
        next
      }

      in_section && $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
        print key "=" value
        key_set = 1
        next
      }

      { print }

      END {
        if (!section_seen) {
          if (NR > 0) print ""
          print "[" section "]"
          print key "=" value
        } else if (in_section && !key_set) {
          print key "=" value
        }
      }
    ' "$file" >"$tmp"
  else
    printf '[%s]\n%s=%s\n' "$section" "$key" "$value" >"$tmp"
  fi

  mv "$tmp" "$file"
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  --light)
    light_mode=true
    ;;
  --dark)
    light_mode=false
    ;;
  "")
    if ! command -v jq >/dev/null 2>&1; then
      printf 'jq is required but was not found in PATH\n' >&2
      exit 1
    fi

    if [ ! -e "$theme_config" ]; then
      printf 'Ambxst theme config not found, skipping: %s\n' "$theme_config" >&2
      exit 0
    fi

    light_mode="$(read_light_mode)"
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

if [ "$light_mode" = "true" ]; then
  mode="light"
  color_scheme="prefer-light"
  gtk_prefer_dark=0
else
  mode="dark"
  color_scheme="prefer-dark"
  gtk_prefer_dark=1
fi

if command -v gsettings >/dev/null 2>&1 &&
  gsettings writable org.gnome.desktop.interface color-scheme >/dev/null 2>&1; then
  gsettings set org.gnome.desktop.interface color-scheme "$color_scheme" || true
fi

set_ini_key "${config_home}/gtk-3.0/settings.ini" Settings gtk-application-prefer-dark-theme "$gtk_prefer_dark"
set_ini_key "${config_home}/gtk-4.0/settings.ini" Settings gtk-application-prefer-dark-theme "$gtk_prefer_dark"

for qtct in qt5ct qt6ct; do
  set_ini_key "${config_home}/${qtct}/${qtct}.conf" Appearance color_scheme_path "${config_home}/${qtct}/colors/ambxst.colors"
  set_ini_key "${config_home}/${qtct}/${qtct}.conf" Appearance custom_palette true
done

printf 'Propagated Ambxst %s preference to app toolkits.\n' "$mode"
